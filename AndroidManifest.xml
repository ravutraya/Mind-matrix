<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.smartlearningapp">

    <application
        android:allowBackup="true"
        android:label="Smart Learning App"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartLearningApp">

        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <activity android:name=".SyllabusActivity" android:exported="false"/>
        <activity android:name=".QuizActivity" android:exported="false"/>
        <activity android:name=".ResultActivity" android:exported="false"/>

    </application>

</manifest>